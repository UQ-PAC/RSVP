strict digraph {
  rankdir="TB"
  graph [fontname="DejaVu Sans" fontsize=11 bgcolor="transparent" pad=0.4 nodesep=0.35 ranksep=0.6]
  node [shape=box style="filled,rounded" fontname="DejaVu Sans" fontsize=10 margin="0.12,0.06"]
