entity Role enum [ "User", "Admin" ];

entity Account = {
    friends: Set<Account>,
    permissions: {
        roles: Set<Role>
    }
};

entity Trait enum [ "A", "B", "C", "D" ];

entity Person = {
    trait: Trait,
    traits: Set<Trait>
};

action introspect appliesTo {
    principal: Account,
    resource: Account
};

action act appliesTo {
    principal: Person,
    resource: Person
};


