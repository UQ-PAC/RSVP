entity Partition = {
    kind: String,
    size: Long
};

entity Directory in Partition = {
    private: Bool,
    files: Set<Directory>
};

entity File in Directory = {
    kind: String,
    size: Long
};

action "manage" appliesTo {
    principal: File,
    resource: [ Directory ]
};

action "write" in [Action::"manage"] appliesTo {
    principal: File,
    resource: [ Directory ]
};

action "read" in [Action::"write"] appliesTo {
    principal: File,
    resource: [ Directory ]
};

action "act" in [Action::"manage"] appliesTo {
    principal: File,
    resource: [ Directory ]
};

