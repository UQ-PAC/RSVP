entity Role enum [ "User", "Admin" ];

entity Account = {
    name: String,
    age: Long,
    role: Role,
    friends: Set<Account>,
};

entity Album = {
    owner: Account,
    private: Bool
};

entity Photo = {
    album: Album,
    size : Long,
    type: String
};

action view appliesTo {
    principal: [ Account ],
    resource: [ Photo ]
};

