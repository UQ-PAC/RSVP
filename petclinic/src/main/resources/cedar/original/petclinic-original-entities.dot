		"PetClinic::Action::\"AddOwner\"" [label="AddOwner"]
	}
	subgraph "cluster_PetClinic::Visitor" {
		label="PetClinic::Visitor"
		"PetClinic::Visitor::\"Anonymous\"" [label="Anonymous"]
	}
