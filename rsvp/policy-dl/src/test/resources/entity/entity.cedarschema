entity Role enum [ "User", "Admin" ];

entity Account = {
    role: Role,
    friends: Set<Account>,
};

entity Album = {
    owner: Account
};

entity Photo = {
    album: Album,
    data: {
        size : Long,
        private: Bool,
        format: String
    }
};

action view appliesTo {
    principal: [ Account ],
    resource: [ Photo ]
};

