// 1. There exists at least one admin in the system
@invariant("ThereBeAdmins")
principal.role == Role::"Admin"
      for some principal: Account;

// 2. Admin accounts should not have albums
@invariant("NoAlbums")
principal.type == Role::"Admin" && !principal.albums.isEmpty()
   for none principal : Account;

@invariant("PhotoSizeLimit")
photo.size > 10
    for none photo: Photo;

// 4. All admins can see all photos of users
@invariant("AdminRights")
principal.type == Role::"Admin" &&
    deny(Action::"viewPhoto", principal, resource)
        for none  principal: Account, resource: Photo;

