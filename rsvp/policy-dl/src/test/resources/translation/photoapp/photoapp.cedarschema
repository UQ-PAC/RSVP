entity Visibility enum [ "Private", "Protected", "Public" ];
entity Role enum [ "User", "Admin" ];

entity Account = {
    name: String,
    age: Long,
    role: Role,
    friends: Set<Account>,
};

entity Album = {
    owner: Account,
    visibility: Visibility
};

entity Photo = {
    album: Album,
    size : Long,
    type: String
};

action "viewPhoto" appliesTo {
    principal: Account,
    resource: Photo,
    context: { }
};

action "removeAlbum" appliesTo {
    principal: Account,
    resource: Album,
    context: { }
};

action "uploadPhoto" appliesTo {
    principal: Account,
    resource: Album,
    context: { }
};

action "createAlbum" appliesTo {
    principal: Account,
    resource: Account,
    context: { }
};

