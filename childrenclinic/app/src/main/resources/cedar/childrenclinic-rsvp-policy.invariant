// ChildrenClinic RSVP Invariants

// ALSO CONSIDER "OPEN-WORLD" SCENARIOS!

// ALSO CONSIDER ASSERTIONS RELATED TO EXPECTED POLICY RESULTS!

// 1. There is at least one Administrator.
@invariant("Administrator existence.")
entity.roles.contains(EmployeeRole::"Administrator")
    for some entity: Employee;

// 2. Employee should have name, clinics, and roles.
@invariant("Employee data.")
entity has name && entity has clinics && entity has roles
    for all entity: Employee;

// 3. Doctor should have level.
@invariant("Doctor data.")
entity.roles.contains(EmployeeRole::"Doctor") --> entity has level
    for all entity: Employee;

// 4. Only Doctor can be "Resident", "Registrar", or "Specialist".
@invariant("Resident, Registrar, or Specialist.")
(
    entity.level == ProfessionalLevel::"Resident" ||
    entity.level == ProfessionalLevel::"Registrar" ||
    entity.level == ProfessionalLevel::"Specialist"
) --> entity.roles.contains(EmployeeRole::"Doctor")
    for all entity: Employee;

// 5. Every "Intern" and "Registrar" must have a manager.
@invariant("Intern and Registrar manager.")
(
    entity.level == ProfessionalLevel::"Intern" ||
    entity.level == ProfessionalLevel::"Registrar"
) --> entity has manager
    for all entity: Employee;

// 6. No Employee can be their own manager.
@invariant("No Employee can be their own manager.")
entity has manager --> entity.manager != entity
    for all entity: Employee;

// 7. ResponsibleAdult should have name and clinics.
@invariant("ResponsibleAdult data.")
entity has name && entity has clinics
    for all entity: ResponsibleAdult;

// 8. Patient should have name, adults, clinics, and doctors.
@invariant("Patient data.")
entity has name && entity has adults && entity has clinics && entity has doctors
    for all entity: Patient;

// 9. Visit should have patient, adults, clinics, doctors, and confidentiality.
@invariant("Visit data.")
entity has patient && entity has adults && entity has clinics && entity has doctors && entity has confidentiality
    for all entity: Visit;
