		"PetClinic::WebPage::\"Home\"" [label="Home"]
		"PetClinic::WebPage::\"FindOwners\"" [label="FindOwners"]
		"PetClinic::WebPage::\"AddNewPet\"" [label="AddNewPet"]
		"PetClinic::WebPage::\"AddVisit\"" [label="AddVisit"]
		"PetClinic::WebPage::\"Error\"" [label="Error"]
		"PetClinic::WebPage::\"EditPet\"" [label="EditPet"]
		"PetClinic::WebPage::\"Veterinarians\"" [label="Veterinarians"]
