entity File = {
    path: Path,
    access: FileAttr,
    permission: FilePermission
};

entity Directory = {
    access: DirAttr,
    path: Path,
    permission: DirPermission
};

type FileAttr = String;
type DirAttr = String;
type FilePermission = {
    read: __cedar::Bool,
    write: __cedar::Bool,
    exec: __cedar::Bool
};

type DirPermission = {
    read: __cedar::Bool,
    write: __cedar::Bool,
    exec: __cedar::Bool
};

type Path = String;

action "introspect" appliesTo {
    principal: [File, Directory],
    resource: [File, Directory]
};


